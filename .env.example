# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173
SESSION_SECRET=your_session_secret_key_here

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb://localhost:27017/veo_lms

# ============================================
# REDIS CONFIGURATION (REQUIRED FOR SESSIONS)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
RESEND_KEY=your_resend_api_key_here

# ============================================
# FILE STORAGE (BACKBLAZE B2 S3)
# ============================================
BLACK_BLAZE_ENDPOINT=https://s3.us-west-000.backblazeb2.com
BLACK_BLAZE_REGION=us-west-000
BLACK_BLAZE_ACCESS_KEY_ID=your_b2_application_key_id
BLACK_BLAZE_SECRET=your_b2_application_key_secret
BUCKET_NAME=your_bucket_name_here

# ============================================
# AWS S3 (COURSE THUMBNAILS & VIDEOS)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_THUMBNAIL_BUCKET=your_thumbnail_bucket_name

# ============================================
# AWS ELEMENTAL MEDIACONVERT
# ============================================
MEDIACONVERT_ROLE=your_mediaconvert_role_arn
MEDIACONVERT_INPUT_BUCKET=your_input_bucket_name
MEDIACONVERT_OUTPUT_BUCKET=your_output_bucket_name


BACKEND_URL=
LAMBDA_SECRET=

CLOUDFLARE_WORKER_URL=

# ============================================
# PLAYBACK TOKEN (HMAC-SHA256)
# Must be identical in backend .env AND Cloudflare Worker secrets.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================
PLAYBACK_TOKEN_SECRET=your_32_byte_hex_secret_here
PLAYBACK_TOKEN_TTL_SECONDS=7200

# ============================================
# RCLONE — S3 → B2 TRANSFER SERVICE
# ============================================
# rclone is used for production-grade HLS file transfers.
# Install: https://rclone.org/install/
#
# No rclone.conf is required — credentials are injected via env vars at runtime.

# Absolute path to the rclone binary. Leave blank if rclone is on PATH.
RCLONE_PATH=

# rclone remote names used internally (must match the names below in env var prefixes).
# Change these only if you need custom remote names.
RCLONE_S3_REMOTE=veolms-s3
RCLONE_B2_REMOTE=veolms-b2

# Parallel transfers for the bulk copy phase (tune based on server resources)
RCLONE_TRANSFERS=16
RCLONE_CHECKERS=8

# Application-level retry rounds (in ADDITION to rclone's own --retries 3 per round)
# Round 1: bulk rclone copy of entire prefix
# Rounds 2-N: targeted per-object copyto for any stragglers
RCLONE_APP_RETRY_ROUNDS=3